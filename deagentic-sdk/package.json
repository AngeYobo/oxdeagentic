{
  "name": "@deagentic/sdk",
  "version": "0.1.0-alpha",
  "description": "TypeScript SDK for DeAgentic Protocol - Deterministic Settlement for AI Agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "defi",
    "agents",
    "escrow",
    "base",
    "ethereum",
    "settlement"
  ],
  "author": "DeAgentic Protocol",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "ethers": "^6.11.0",
    "viem": "^2.7.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/deagentic/protocol"
  }
}
